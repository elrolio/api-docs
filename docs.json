              "guides/webhooks",
              "guides/common-workflows",
              "guides/working-with-jobs"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/billing",
              "resources/media-requirements",
              "resources/security",
              "resources/known-issues",
              "resources/glossary",
